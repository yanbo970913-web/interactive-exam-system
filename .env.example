# 將此檔案複製為 .env 並填入真實值
# Copy this file to .env and fill in your values
# ⚠️  絕對不要將 .env 上傳至 GitHub！（已加入 .gitignore）

# ── 管理者帳號設定（首次執行 npm run seed 前必填）────────────
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_secure_admin_password_min_8_chars
ADMIN_DISPLAY_NAME=系統管理員

# ── 伺服器設定 ─────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── JWT 密鑰（請改為至少 32 字元的隨機字串）─────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars

# ── JWT 過期時間 ───────────────────────────────────────────
JWT_EXPIRES_IN=8h

# ── Anthropic API Key（留空則自動切換為本地模擬 AI 模式）─────
ANTHROPIC_API_KEY=

# ── AI 模型 ────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 資料庫路徑 ─────────────────────────────────────────────
DB_PATH=./data/exam_system.db
